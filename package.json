{
  "name": "expenses-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "start": "vite preview --host",
    "cf:preview": "bun run build && bunx wrangler dev",
    "cf:preview:staging": "bun run build:staging && bunx wrangler dev --env staging",
    "cf:deploy": "bun run build && bunx wrangler deploy",
    "cf:deploy:staging": "bun run build:staging && bunx wrangler deploy --env staging",
    "lint": "eslint . --max-warnings=0",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun run format:check",
    "dev:web": "vite dev",
    "dev:convex": "bunx convex dev",
    "dev": "bun run scripts/dev.ts",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.58.0",
    "@convex-dev/react-query": "^0.0.0-alpha.11",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "5.96.2",
    "@tanstack/react-router": "1.168.10",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.104",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.539.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "^3.4.0",
    "uqr": "^0.1.2",
    "use-sync-external-store": "^1.6.0",
    "vite-bundle-analyzer": "^1.3.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "1.167.12",
    "@types/bun": "^1.3.2",
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  }
}
