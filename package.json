{
  "name": "expenses-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "start": "vite preview --host",
    "cf:preview": "bun run build && bunx wrangler dev",
    "cf:preview:staging": "bun run build:staging && bunx wrangler dev --env staging",
    "cf:deploy": "bun run build && bunx wrangler deploy",
    "cf:deploy:staging": "bun run build:staging && bunx wrangler deploy --env staging",
    "lint": "eslint . --max-warnings=0",
    "test": "bun test",
    "check": "bun run lint && bun run typecheck && bun run format:check",
    "dev:web": "vite dev",
    "dev:convex": "bunx convex dev",
    "dev": "bun run scripts/dev.ts",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.58.0",
    "@convex-dev/react-query": "^0.1.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-virtual": "^3.14.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.0",
    "convex-helpers": "^0.1.120",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0",
    "uqr": "^0.1.3",
    "use-sync-external-store": "^1.6.0",
    "vite-bundle-analyzer": "^1.3.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/router-plugin": "1.168.18",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "wrangler": "^4.105.0"
  }
}
